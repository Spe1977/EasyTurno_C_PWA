{
  "name": "easyturno",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "NG_CLI_ANALYTICS=false ng serve",
    "dev:pw": "NG_CLI_ANALYTICS=false ng serve --watch=false --host 127.0.0.1 --port 3100",
    "build": "ng build",
    "preview": "NG_CLI_ANALYTICS=false ng serve --configuration=production",
    "format": "prettier --write \"src/**/*.{ts,html,css,scss,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,css,scss,json}\"",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepare": "husky",
    "build:mobile": "npm run build && npx cap sync",
    "android:dev": "npm run build:mobile && npx cap open android",
    "android:build": "npm run build && npx cap sync && cd android && ./gradlew assembleRelease",
    "cap:sync": "npx cap sync",
    "cap:update": "npm run build && npx cap sync",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "dev:e2e": "NG_CLI_ANALYTICS=false ng serve --watch=false",
    "e2e": "start-server-and-test dev:e2e http://localhost:3000 cypress:run",
    "test:pw": "playwright test",
    "test:pw:ui": "playwright test --ui",
    "test:pw:headed": "playwright test --headed",
    "test:pw:debug": "playwright test --debug",
    "test:pw:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "@angular/build": "^21.2.5",
    "@angular/cli": "^21.2.5",
    "@angular/common": "^21.2.5",
    "@angular/compiler": "^21.2.5",
    "@angular/compiler-cli": "^21.2.5",
    "@angular/core": "^21.2.5",
    "@angular/forms": "^21.2.5",
    "@angular/platform-browser": "^21.2.5",
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/local-notifications": "^8.0.2",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@tailwindcss/postcss": "^4.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@angular/platform-browser-dynamic": "^21.2.5",
    "@playwright/test": "^1.58.2",
    "@cypress/angular": "^4.0.0",
    "@eslint/js": "^9.36.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.6.2",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "cypress": "^15.3.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-preset-angular": "^16.1.1",
    "lint-staged": "^16.2.3",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "start-server-and-test": "^2.1.2",
    "tailwindcss": "^4.2.2",
    "ts-jest": "^29.4.4",
    "typescript": "^5.9.3",
    "vite": "^7.1.9",
    "zone.js": "^0.15.1"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix --no-warn-ignored",
      "jest --bail --findRelatedTests --passWithNoTests"
    ],
    "*.html": [
      "prettier --write"
    ],
    "*.css": [
      "prettier --write"
    ]
  },
  "overrides": {
    "handlebars": "4.7.9"
  }
}
